library(multiclock_lib) {
  cell(BUF) {
    pin(A) { direction : input; }
    pin(Y) {
      direction : output;
      timing() {
        related_pin : "A";
        timing_type : combinational;
        cell_rise(scalar) { values("0.15"); }
        cell_fall(scalar) { values("0.10"); }
      }
    }
  }

  cell(DFFQ) {
    pin(CLK) { direction : input; clock : true; }
    pin(D) {
      direction : input;
      timing() {
        related_pin : "CLK";
        timing_type : setup_rising;
        rise_constraint(scalar) { values("0.25"); }
      }
      timing() {
        related_pin : "CLK";
        timing_type : hold_rising;
        rise_constraint(scalar) { values("0.08"); }
      }
    }
    pin(Q) {
      direction : output;
      timing() {
        related_pin : "CLK";
        timing_type : rising_edge;
        cell_rise(scalar) { values("0.32"); }
        cell_fall(scalar) { values("0.25"); }
      }
    }
  }
}
