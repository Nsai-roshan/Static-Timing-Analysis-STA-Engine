library(basic_lib) {
  cell(BUF) {
    pin(A) { direction : input; }
    pin(Y) {
      direction : output;
      timing() {
        related_pin : "A";
        timing_type : combinational;
        timing_sense : positive_unate;
        cell_rise(scalar) { values("0.18"); }
        cell_fall(scalar) { values("0.12"); }
      }
    }
  }

  cell(AND2X1) {
    pin(A) { direction : input; }
    pin(B) { direction : input; }
    pin(Y) {
      direction : output;
      timing() {
        related_pin : "A";
        timing_type : combinational;
        timing_sense : positive_unate;
        cell_rise(scalar) { values("0.24"); }
        cell_fall(scalar) { values("0.20"); }
      }
      timing() {
        related_pin : "B";
        timing_type : combinational;
        timing_sense : positive_unate;
        cell_rise(scalar) { values("0.26"); }
        cell_fall(scalar) { values("0.22"); }
      }
    }
  }

  cell(DFFQ) {
    pin(CLK) { direction : input; clock : true; }
    pin(D) {
      direction : input;
      timing() {
        related_pin : "CLK";
        timing_type : setup_rising;
        rise_constraint(scalar) { values("0.35"); }
      }
      timing() {
        related_pin : "CLK";
        timing_type : hold_rising;
        rise_constraint(scalar) { values("0.08"); }
      }
    }
    pin(Q) {
      direction : output;
      timing() {
        related_pin : "CLK";
        timing_type : rising_edge;
        cell_rise(scalar) { values("0.40"); }
        cell_fall(scalar) { values("0.30"); }
      }
    }
  }
}
